        given-names: Joohan
      - family-names: Meyer
        given-names: David
      - family-names: Sorkin
        given-names: Rafael D.
    title: "Space-time as a causal set"
    journal: "Physical Review Letters"
    volume: 59
    pages: 521
    year: 1987
    doi: "10.1103/PhysRevLett.59.521"
